# 로컬 Cloudflare 프리뷰(`npm run cf:dev`)에서 Functions 가 사용하는 시크릿.
# 이 파일을 복사해 .dev.vars 로 만들고 값을 채우세요:  cp .dev.vars.example .dev.vars
# (.dev.vars 는 .gitignore 로 커밋되지 않습니다. 절대 키를 커밋하지 마세요.)
OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXX
# OPENAI_MODEL=gpt-5.4-mini
# OPENAI_IMAGE_MODEL=gpt-image-2

# 네이버 검색광고 API (키워드 조회) — 검색광고 시스템 > 도구 > API 사용관리
NAVER_AD_API_KEY=01000000xxxxxxxx
NAVER_AD_SECRET_KEY=AQAAAAxxxxxxxx
NAVER_AD_CUSTOMER_ID=1234567

# Resend (일일보고서 이메일 발송) — resend.com > API Keys
RESEND_API_KEY=
# 발신 주소(인증한 도메인과 일치해야 함). 미설정 시 report@12sang.com
# RESEND_FROM=report@12sang.com
