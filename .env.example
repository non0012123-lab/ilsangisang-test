# Supabase 연결 정보 (대시보드 → Project Settings → API)
# 이 파일을 복사해 .env 로 만들고 값을 채우세요:  cp .env.example .env
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
# 최신 publishable key (sb_publishable_...) — 브라우저에서 안전 (RLS 필수)
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_XXXXXXXXXXXXXXXXXXXX
# (레거시 프로젝트라면 대신 anon key 사용 가능)
# VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# ───────────────────────────────────────────────────────────────
# OpenAI (AI 기획 어시스턴트) — Cloudflare Pages Function 에서만 사용
#  ⚠️ VITE_ 접두사를 붙이지 마세요. 붙이면 브라우저 번들에 키가 노출됩니다.
#  로컬: `npx wrangler pages dev` 실행 시 .dev.vars 파일이나 환경변수로 주입.
#  배포: Cloudflare Pages → Settings → Environment variables 에 Secret 으로 등록.
# OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXX
# OPENAI_MODEL=gpt-5.4-mini            # 텍스트 기획 리포트 (/api/ai-plan)
# OPENAI_IMAGE_MODEL=gpt-image-2 # 이미지 시안 (/api/ai-image)
