# Supabase 연결 정보 (대시보드 → Project Settings → API)
# 이 파일을 복사해 .env 로 만들고 값을 채우세요:  cp .env.example .env
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
# 최신 publishable key (sb_publishable_...) — 브라우저에서 안전 (RLS 필수)
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_XXXXXXXXXXXXXXXXXXXX
# (레거시 프로젝트라면 대신 anon key 사용 가능)
# VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
