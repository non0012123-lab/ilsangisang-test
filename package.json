{
  "name": "myapp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://non0012123-lab.github.io/ilsangisang-test",
  "scripts": {
    "dev": "vite",
    "check:functions": "esbuild $(find functions -name '*.ts') --outdir=node_modules/.cache/fn-check --format=esm --log-level=error",
    "build": "tsc -b && npm run check:functions && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy": "npm run build && gh-pages -d dist",
    "cf:dev": "npm run build && wrangler pages dev",
    "cf:preview": "npm run build && wrangler pages deploy --branch preview",
    "cf:deploy": "npm run build && wrangler pages deploy"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.2",
    "gh-pages": "^6.3.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.17.0",
    "playwright": "^1.60.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.16.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "wrangler": "^4.95.0"
  }
}
