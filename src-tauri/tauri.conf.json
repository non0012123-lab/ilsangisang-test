{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "일상이상",
  "version": "0.1.0",
  "identifier": "com.ilsangisang.desktop",
  "build": {
    "frontendDist": "../dist",
    "beforeBuildCommand": "npx vite build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "일상이상 커뮤니케이션",
        "url": "https://ilsangisang-test.pages.dev",
        "width": 1280,
        "height": 820,
        "minWidth": 380,
        "minHeight": 480,
        "resizable": true,
        "center": true
      },
      {
        "label": "assistant",
        "title": "AI 어시스턴트",
        "url": "https://ilsangisang-test.pages.dev/widget",
        "width": 560,
        "height": 540,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": false
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/non0012123-lab/ilsangisang-test/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgyMzVFQkVCMUNEMjk3NjAKUldSZ2w5SWM2K3MxZ21UaFg3dzZDR2lBRkVRTUwrc3czWEVENW9VVFpYYXFyWDlYbUtmMFhuMXcK"
    }
  }
}
